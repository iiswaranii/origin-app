{
  "name": "origin-app",
  "version": "1.0.0",
  "description": "Origin is an AI-powered self-understanding platform that builds a living graph of thoughts, emotions, values, memories, and recurring patterns to reveal hidden connections within a person's life.",
  "main": "index.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:schema": "psql -U postgres -d origin_app -f src/db/schema.sql",
    "db:seed": "psql -U postgres -d origin_app -f src/db/seed.sql",
    "db:reset": "dropdb -U postgres origin_app && createdb -U postgres origin_app && npm run db:schema && npm run db:seed"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iiswaranii/origin-app.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/iiswaranii/origin-app/issues"
  },
  "homepage": "https://github.com/iiswaranii/origin-app#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14"
  }
}
